  "keyFeatures": [
    "Creature collection with growth stages (Small → Medium → Large)",
    "PVP battle system with RNG + elemental type advantages",
    "Mathematical inventory with fixed 20-slot backpack and item stacking",
    "Disease & vaccine system that modifies evolution requirements",
    "Real-time-like friend chat via short polling with RxJS",
    "Daily reward system granting a random Xoxemon and items",
    "Admin dashboard for managing users, items, and global game balance settings",
    "Full JWT-based authentication with double-guard admin protection",
    "Fully containerised with Docker Compose (frontend, backend, MySQL)"
  ],
